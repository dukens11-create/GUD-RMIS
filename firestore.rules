rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // True only when the request comes from a signed-in Firebase Auth user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // True when the requesting user owns the document via a `userId` field.
    function isOwner() {
      return request.auth.uid == resource.data.userId;
    }

    // True when the requesting user's custom claim marks them as admin.
    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // Reject writes that try to alter the immutable `createdAt` timestamp.
    function doesNotAlterCreatedAt() {
      return !('createdAt' in request.resource.data) ||
             request.resource.data.createdAt == resource.data.createdAt;
    }

    // ── Drivers ──────────────────────────────────────────────────────────────
    // All authenticated users can read drivers.
    // Only admins can create/update/delete driver records.
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin() && doesNotAlterCreatedAt();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Vehicles ─────────────────────────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && isAdmin() && doesNotAlterCreatedAt();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Loads ─────────────────────────────────────────────────────────────────
    match /loads/{loadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && doesNotAlterCreatedAt();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Invoices ─────────────────────────────────────────────────────────────
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && doesNotAlterCreatedAt();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Incidents ────────────────────────────────────────────────────────────
    // Any authenticated user can report and read incidents.
    // Only admins can delete incident records.
    match /incidents/{incidentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && doesNotAlterCreatedAt();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Tasks ─────────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && doesNotAlterCreatedAt();
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
